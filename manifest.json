{
  "manifest_version": 3,
  "name": "TokenLens Capture",
  "version": "1.0.0",
  "description": "Capture AI conversations and analyze token usage with TokenLens",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://v0.dev/*",
    "https://v0.app/*",
    "*://v0.app/*",
    "*://*.v0.app/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://v0.dev/*",
        "https://v0.app/*",
        "*://v0.app/*",
        "*://*.v0.app/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
